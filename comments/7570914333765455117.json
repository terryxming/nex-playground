nail": "https://p16-common-sign.tiktokcdn-us.com/tos-useast5-avt-0068-tx/0559cd7618010e45359334d7e8914449~tplv-tiktokx-cropcenter:100:100.jpg?dr=9640&refresh_token=5af5fb37&x-expires=1775750400&x-signature=JRXNK%2FBERh8nZmFvizaf884sznE%3D&t=4d5b0474&ps=13740610&shp=30310797&shcp=ff37627b&idc=useast5", "mentions": [], "detailedMentions": [], "text_zh": "远离屏幕啊"}, {"videoWebUrl": "https://www.tiktok.com/@findsbydhd/video/7570914333765455117", "submittedVideoUrl": "https://www.tiktok.com/@findsbydhd/video/7570914333765455117", "input": "https://www.tiktok.com/@findsbydhd/video/7570914333765455117", "cid": "7613536785725457183", "createTime": 1772664694, "createTimeISO": "2026-03-04T22:51:34.000Z", "text": "With the price of healthcare in America that’s not a terrible prescription cost.", "diggCount": 0, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 0, "uid": "7115580798490379310", "uniqueId": "rycette", "avatarThumbnail": "https://p16-common-sign.tiktokcdn-us.com/tos-useast5-avt-0068-tx/b8a0c366be8a9def0146a397e9f792eb~tplv-tiktokx-cropcenter:100:100.jpg?dr=9640&refresh_token=82a1f3f7&x-expires=1775750400&x-signature=k5wfAzkBn5r4mEj73smT6km3SMM%3D&t=4d5b0474&ps=13740610&shp=30310797&shcp=ff37627b&idc=useast5", "mentions": [], "detailedMentions": [], "text_zh": "考虑到美国医疗保健的价格，这（此处“prescription”可能指购买设备或服务的成本，或与前面医疗相关的误译）不算是个糟糕的处方药费用。"}, {"videoWebUrl": "https://www.tiktok.com/@findsbydhd/video/7570914333765455117", "submittedVideoUrl": "https://www.tiktok.com/@findsbydhd/video/7570914333765455117", "input": "https://www.tiktok.com/@findsbydhd/video/7570914333765455117", "cid": "7585460190695605022", "createTime": 1766127714, "createTimeISO": "2025-12-19T07:01:54.000Z", "text": "Oh yes a prescription for my daily meds (aka video games )", "diggCount": 0, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 0, "uid": "7404026436125967406", "uniqueId": "littlegoddessbabym", "avatarThumbnail": "