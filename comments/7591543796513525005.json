[{"videoWebUrl": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "submittedVideoUrl": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "input": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "cid": "7591659864146772766", "createTime": 1767571138, "createTimeISO": "2026-01-04T23:58:58.000Z", "text": "Nintendo found what worked with the Switch one and two. They don’t need to copy the Nex because the Nex playground isn’t competition for Nintendo. This system is selling well now, but eventually get board with it like they did the Xbox Kinect.", "diggCount": 5, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 0, "uid": "7000548648954577925", "uniqueId": "digitallatte", "avatarThumbnail": "https://p16-common-sign.tiktokcdn-us.com/tos-useast5-avt-0068-tx/7346421419711938606~tplv-tiktokx-cropcenter:100:100.jpg?dr=9640&refresh_token=dd657399&x-expires=1775754000&x-signature=FptDEC2W1icQaPjnYmDY4l4Ud%2Bk%3D&t=4d5b0474&ps=13740610&shp=30310797&shcp=ff37627b&idc=useast5", "mentions": [], "detailedMentions": [], "text_zh": "任天堂从 Switch 上找到了适合一个和两个玩家的东西。他们不需要模仿 Nex，因为 Nex 游乐场对任天堂构不成竞争。这个系统现在卖得很好，但最终他们会厌倦它，就像他们厌倦 Xbox Kinect 一样。"}, {"videoWebUrl": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "submittedVideoUrl": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "input": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "cid": "7591600192081527607", "createTime": 1767557196, "createTimeISO": "2026-01-04T20:06:36.000Z", "text": "Its just a bad Xbox Kinnect", "diggCount": 47, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 9, "uid": "11160757", "uniqueId": "404incorrect", "avatarThumbnail": "https://p16-common-sign.tiktokcdn-us.com/tos-useast5-avt-0068-tx/88fa58b3665ef104fb8429bc9bf80509~tplv-tiktokx-cropcenter:100:100.jpg?dr=9640&refresh_token=16f701a8&x-expires=1775754000&x-signature=F%2B2S0zT%2B6iTMAEKmnh8gz0bfSD0%3D&t=4d5b0474&ps=13740610&shp=30310797&shcp=ff37627b&idc=useast5", "mentions": [], "detailedMentions": [], "text_zh": "这玩意儿就是个烂Xbox Kinnect"}, {"videoWebUrl": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "submittedVideoUrl": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "input": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "cid": "7591553013200241438", "createTime": 1767546221, "createTimeISO": "2026-01-04T17:03:41.000Z", "text": "I mean, they’re watching it as much as they watched the Xbox One using their motion camera. NEX is an option that left the market a while back, this isn’t new. Like you said, Nintendo has priced themselves out by not having a new age GBA/GB/DS/WII on the market.", "diggCount": 13, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 3, "uid": "289375018843611136", "uniqueId": "rokoxpb", "avatarThumbnail": "https://p16-common-sign.tiktokcdn-us.com/tos-maliva-avt-0068/ec10ce38f86112836ee75d64a028aeee~tplv-tiktokx-cropcenter:100:100.jpg?dr=9640&refresh_token=f510c113&x-expires=1775754000&x-signature=X8cJ5euFhGHqUqWrjyQcMjWGUh4%3D&t=4d5b0474&ps=13740610&shp=30310797&shcp=ff37627b&idc=useast5", "mentions": [], "detailedMentions": [], "text_zh": "我的意思是，他们看这个的次数跟他们用体感摄像头看Xbox One一样多。NEX（体感游戏机）也是一个很早以前退市的选项，这不是什么新鲜事。就像你说的，任天堂没有推出新的GBA/GB/DS/Wii时代的产品，自己把自己定价太高了。"}, {"videoWebUrl": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "submittedVideoUrl": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "input": "https://www.tiktok.com/@kitandkrysta/video/7591543796513525005", "cid": "7599142451307447053", "createTime": 1769313255, "createTimeISO": "2026-01-25T03:54:15.000Z", "text": "Nintendo do not GAF 😭", "diggCount": 14, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 0, "uid": "7043460278698705967", "uniqueId": "blizziboitv", "avatarThumbnail": "https:/