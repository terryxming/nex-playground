[{"videoWebUrl": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "submittedVideoUrl": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "input": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "cid": "7573698842362708766", "createTime": 1763389213, "createTimeISO": "2025-11-17T14:20:13.000Z", "text": "You’re not alone and you’re definitely not crazy!! think my son would love this so I decided to do more research and see if anyone else was concerned about the camera. I’m going to take this as a sign not to get it because I’m just as paranoid. Ever since my son’s owlet camera was hacked and a grown man was speaking to him through it, I’ll never be the same. Everything is hackable these days and people are digusting. I don’t even trust the people who made it because how do we know they don’t record and store our kids playing? Yea no thanks.", "diggCount": 0, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 1, "uid": "6774537263651341317", "uniqueId": "erikafiore", "avatarThumbnail": "https://p16-common-sign.tiktokcdn-us.com/tos-maliva-avt-0068/e6bd2f5e40fa4cc0bf210e6b03c47812~tplv-tiktokx-cropcenter:100:100.jpg?dr=9640&refresh_token=e905e874&x-expires=1775754000&x-signature=Z3gt9Rn3B2ZaU%2Fh1GBmKVkWipPI%3D&t=4d5b0474&ps=13740610&shp=30310797&shcp=ff37627b&idc=useast8", "mentions": [], "detailedMentions": [], "text_zh": "你不是一个人，你绝对没疯！！我觉得我儿子会喜欢这个，所以我决定再研究一下，看看其他人是否也担心摄像头。我把这个当个信号，不买了，因为我也一样偏执。自从我儿子的 Owlet 摄像头被黑了，一个大男人通过它对他说话后，我就再也无法平静了。现在什么都可能被黑，而且人们太恶心了。我甚至不相信制造它的人，我们怎么知道他们不会录下并存储我们孩子玩耍的样子？我可不想要。"}, {"videoWebUrl": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "submittedVideoUrl": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "input": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "cid": "7558800996651516703", "createTime": 1759920546, "createTimeISO": "2025-10-08T10:49:06.000Z", "text": "I would say yes 😬 but we have one & it’s extremely cool!! My kids love it. When you’re not using it, it has a magnet to cover the camera. I keep ours unplugged though because I’m weird lol", "diggCount": 1, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 1, "uid": "6816506012817294342", "uniqueId": "bjmk91", "avatarThumbnail": "https://p16-common-sign.tiktokcdn-us.com/tos-useast8-avt-0068-tx2/d790c073e9f0c9744926366bb189bd3c~tplv-tiktokx-cropcenter:100:100.jpg?dr=9640&refresh_token=81350f2c&x-expires=1775754000&x-signature=DbE0tvH1LKNWVp%2FSUYf%2FZytDgEY%3D&t=4d5b0474&ps=13740610&shp=30310797&shcp=ff37627b&idc=useast8", "mentions": [], "detailedMentions": [], "text_zh": "我会说（给孩子买）😬，但我们家已经有一个了，而且它超级酷！！我的孩子们超爱它。不玩的时候，它有个磁铁可以盖住摄像头。我平时都把它拔掉插头，因为我有点怪癖哈哈"}, {"videoWebUrl": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "submittedVideoUrl": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "input": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "cid": "7558871016282358542", "createTime": 1759936846, "createTimeISO": "2025-10-08T15:20:46.000Z", "text": "It definitely seems like it could be hacked lol but if you have the camera covered and it unplugged when not using it might be okay- I just got the tonie box for brixton! No camera, just story telling and music. I’m super excited", "diggCount": 0, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 4, "uid": "6623966796394708998", "uniqueId": "itszoesmallwood", "avatarThumbnail": "https://p16-common-sign.tiktokcdn-us.com/tos-useast5-avt-0068-tx/35fc73b95c44fbae72800d785bb3590c~tplv-tiktokx-cropcenter:100:100.jpg?dr=9640&refresh_token=0848e0e0&x-expires=1775754000&x-signature=sb%2BPzAsyq4UpK8Gb6pN3zxSpPYs%3D&t=4d5b0474&ps=13740610&shp=30310797&shcp=ff37627b&idc=useast8", "mentions": [], "detailedMentions": [], "text_zh": "感觉很容易被黑客入侵啊 lol，但如果摄像头盖好，不用的时候拔掉插头，可能还可以- 我刚给我家 Brixton 买了个 Tonie Box！没有摄像头，只有讲故事和音乐。我超期待"}, {"videoWebUrl": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "submittedVideoUrl": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "input": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "cid": "7558674589808575262", "createTime": 1759891089, "createTimeISO": "2025-10-08T02:38:09.000Z", "text": "Anything with a camera and internet connection can be hacked and viewed", "diggCount": 5, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 2, "uid": "6882800678005425158", "uniqueId": "sweetestsagittarius", "avatarThumbnail": "https://p16-common-sign.tiktokcdn-us.com/tos-useast8-avt-0068-tx2/c2ecc65910608f0828efd56b28683b6f~tplv-tiktokx-cropcenter:100:100.jpg?dr=9640&refresh_token=49b79eee&x-expires=1775754000&x-signature=aClNsTTbSETo3rT6HB26iqFktpQ%3D&t=4d5b0474&ps=13740610&shp=30310797&shcp=ff37627b&idc=useast8", "mentions": [], "detailedMentions": [], "text_zh": "任何带摄像头和网络连接的东西都可能被黑客入侵和观看"}, {"videoWebUrl": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "submittedVideoUrl": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "input": "https://www.tiktok.com/@alextiehes/video/7558656784253078839", "cid": "7570775757883392823", "createTime": 1762708608, "createTimeISO": "2025-11-09T17:16:48.000Z", "text": "any camera can be hacked - your phone camera, any camera attached to a laptop or external one, etc", "diggCount": 2, "likedByAuthor": false, "pinnedByAuthor": false, "repliesToId": null, "replyCommentTotal": 0, "uid": "7452239179571627054", "uniqueId": "imjustagirl0024", "avatarThumbnail": "https://p16-common-sign.tiktokcdn-us.com/tos-useast5-avt-0068-tx/16b622979450c827c72fabd329d8d02a~tplv-tiktokx-cropcenter:100:100.jpg?dr=9640&refresh_token=765ae58e&x-expires=1775754000&x-signature=ZGiotv2LPUcJyXjcllFx5lTtxvQ%3D&t=4d5b0474&ps=13740610&shp=30310797&shcp=ff37627b&idc=useast8", "mentions": [], "detailedMentions": [], "text_zh": "任何摄像头都可能被黑——你的手机摄像头，笔记本电脑连接的任何摄像头，外接摄像头，等等"}, {"v